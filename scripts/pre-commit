#!/usr/bin/env bash
set -euo pipefail

# Mycelia repo pre-commit hook: block import statements inside Julia function
# bodies. Julia does not allow `import` at function scope — it causes:
#   syntax: "import" expression not at top level
# which breaks Pkg.precompile and prevents the package from loading.
#
# This hook runs in two scenarios:
# 1. Called by the global hook (~/workspace/dotfiles/hooks/pre-commit) which
#    delegates to repo-local scripts/pre-commit if it exists.
# 2. Installed directly via: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit
#    (for users who don't have the global hook configured)
#
# Setup for users without global hooks:
#   cd ~/workspace/Mycelia
#   ln -sf ../../scripts/pre-commit .git/hooks/pre-commit

errors=0

# Check all staged .jl files (not just src/ — tests/ and scripts/ count too)
staged_jl=$(git diff --cached --name-only --diff-filter=ACM -- '*.jl' 2>/dev/null)

if [[ -z "${staged_jl}" ]]; then
    exit 0
fi

for file in ${staged_jl}; do
    # Get the staged content (not working tree)
    content=$(git show ":${file}" 2>/dev/null) || continue

    # Find import statements that are indented (inside a function body).
    # Top-level imports have zero indentation; function-level ones are indented.
    matches=$(printf '%s\n' "${content}" | grep -nE '^[[:space:]]+import ' 2>/dev/null || true)

    if [[ -n "${matches}" ]]; then
        echo "ERROR: import inside function body in ${file}:"
        printf '%s\n' "${matches}" | while IFS= read -r line; do
            echo "  ${line}"
        done
        echo ""
        errors=$((errors + 1))
    fi
done

if [[ ${errors} -gt 0 ]]; then
    echo "  Julia does not allow import at function scope."
    echo "  Move imports to module level (top of file or Mycelia.jl)."
    echo ""
    echo "=== COMMIT BLOCKED: ${errors} file(s) with import-in-function ==="
    exit 1
fi

# Check for @eval monkeypatching in test files without zz_ prefix.
# See .codex/skills/test-isolation/SKILL.md for the full convention.
eval_warnings=0
staged_test_jl=$(printf '%s\n' "${staged_jl}" | grep '^test/' || true)

for file in ${staged_test_jl}; do
    basename_file=$(basename "${file}")
    if [[ "${basename_file}" == zz_* ]]; then
        continue
    fi
    content=$(git show ":${file}" 2>/dev/null) || continue
    eval_matches=$(printf '%s\n' "${content}" | grep -nE '@eval\s+Mycelia' 2>/dev/null || true)
    if [[ -n "${eval_matches}" ]]; then
        echo "WARNING: @eval Mycelia in ${file} (no zz_ prefix):"
        printf '%s\n' "${eval_matches}" | while IFS= read -r line; do
            echo "  ${line}"
        done
        echo "  See .codex/skills/test-isolation/SKILL.md for alternatives."
        echo ""
        eval_warnings=$((eval_warnings + 1))
    fi
done

if [[ ${eval_warnings} -gt 0 ]]; then
    echo "=== WARNING: ${eval_warnings} test file(s) use @eval Mycelia without zz_ prefix ==="
    echo "  This can leak global state into subsequent test files."
    echo "  Consider: zz_ prefix, save/restore pattern, or fake CONDA_RUNNER approach."
    echo ""
fi
